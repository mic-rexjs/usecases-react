{
  "compilerOptions": {
    "strictNullChecks": true,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "ES2020",
    "allowJs": false,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strict": true,
    "resolveJsonModule": true,
    "strictPropertyInitialization": true,
    "lib": ["ESNext", "DOM"],
    "outDir": "./build",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["./build"]
}
